# Plaid credentials — obtain from https://dashboard.plaid.com
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_secret
# "sandbox" or "production" (Plaid retired "development" in June 2024)
PLAID_ENV=sandbox
# OAuth redirect URI for banks like Chase — set to your deployed https://<app>/link and
# register the same URL in the Plaid dashboard. Leave blank locally (no OAuth on sandbox).
PLAID_REDIRECT_URI=

# SQLite database path (on Railway, point into the mounted volume, e.g. sqlite:////data/lucre.db)
DATABASE_URL=sqlite:///data/lucre.db

# Encryption key for storing Plaid access tokens at rest
# Generate with: uv run python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your_fernet_key_here

# Login password hash — generate with: uv run python scripts/hash_password.py
APP_PASSWORD_HASH=your_argon2_password_hash

# Session cookie signing secret — generate with: uv run python -c "import secrets; print(secrets.token_urlsafe(32))"
SESSION_SECRET=your_session_secret

# Email (Resend) — optional until alerts are enabled
RESEND_API_KEY=
ALERT_FROM_EMAIL=
ALERT_TO_EMAIL=

# Local development only: allow the session cookie over http://localhost.
# Leave unset (defaults true) in production.
COOKIE_SECURE=false
